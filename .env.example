# ─── Shared by docker-compose ───────────────────────────────────────────────

# Image tag pulled from ghcr.io/the-code-labz/yt-downloader/{backend,worker,frontend}.
# Published multi-arch (linux/amd64 + linux/arm64) by .github/workflows/publish.yml
# on every push to main / version tag — works unmodified on Debian/Ubuntu x86_64
# hosts and on ARM hosts (e.g. Oracle Cloud Ampere A1 free tier).
IMAGE_TAG=latest

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings-api
SUPABASE_SCHEMA=neuroarchive            # custom Postgres schema; must be in 'Exposed schemas'

# Cloudflare R2 (S3-compatible)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=neuroarchive
R2_PUBLIC_BASE_URL=                # optional; if set, used in place of signed URLs

# Redis
REDIS_URL=redis://redis:6379/0

# YouTube bot-check ("Sign in to confirm you're not a bot"): path to a
# Netscape-format cookies.txt INSIDE the worker container. Default below
# matches the shared `cookies-data` volume that scripts/refresh_cookies.py
# feeds via POST /admin/cookies (dynamic, no restart needed). For a manual
# one-off export instead, see README § YouTube bot-check.
YTDLP_COOKIES_FILE=/data/cookies/cookies.txt

# Shared secret required by scripts/refresh_cookies.py to call
# PUT /admin/cookies. Leave unset to disable the endpoint entirely (404s).
# Generate with: openssl rand -hex 32
ADMIN_SECRET=

# Proxy yt-dlp's outbound requests through — e.g. a SOCKS5 tunnel back to a
# residential/home network (see README § Bypass via a home-network proxy).
# Leave unset for direct egress from this host.
# YTDLP_PROXY=socks5://user:pass@100.x.y.z:1080

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Behaviour
AUTO_DELETE_DAYS=0                 # 0 disables auto-delete
SIGNED_URL_TTL_SECONDS=3600
MAX_CONCURRENT_DOWNLOADS=2

# Frontend (Vite)
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
